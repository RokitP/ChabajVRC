const { Client } = require("node-osc");
const raise = require("superscript-text");
function config(){
	try {return require("./config.local.json");}
	catch {return require("./config.json");}
};
const cfg = config();
cli = new Client(cfg.client.ip, 9000);
displaytext = `${raise("chabaj")}
👤${cfg.info.main.name}
${cfg.info.main.pronouns}
{cfg.info.optional.ageenabled ? `${cfg.info.optional.age} y/o` : ""}
${cfg.info.optional.statusenabled ? `` : ""}
${cfg.info.optional.extrainfoenabled ? `\nextra info:\n${cfg.info.optional.extrainfo}` : ""}`;
console.clear();
console.log(`Now displaying:\n\n${displaytext}`);
setInterval(() => cli.send("/chatbox/input", displaytext, true, false), 2000);
